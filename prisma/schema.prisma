generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Word {
  id             String            @id @default(uuid())
  text           String
  textTranslated String
  soundUrl       String
  createdAt      DateTime          @db.Timestamptz(6)
  userId         String
  sentences      ExampleSentence[]
  user           User              @relation(fields: [userId], references: [id])

  @@map("words")
}

model ExampleSentence {
  id             String   @id @default(uuid())
  text           String
  textTranslated String
  soundUrl       String
  createdAt      DateTime @db.Timestamptz(6)
  wordId         String
  word           Word     @relation(fields: [wordId], references: [id])

  @@map("exampleSentences")
}

model StudySession {
  id        String   @id @default(uuid())
  type      String
  minutes   Int
  createdAt DateTime @default(now()) @db.Timestamptz

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("studySessions")
}

model CommonPhrase {
  id             String                 @id @default(uuid())
  text           String
  textTranslated String
  soundUrl       String                 @default("")
  createdAt      DateTime               @default(now()) @db.Timestamptz
  userId         String
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories     CommonPhraseCategory[]

  @@map("commonPhrases")
}

model Category {
  id      String                 @id @default(uuid())
  name    String                 @unique
  phrases CommonPhraseCategory[]

  @@map("categories")
}

model CommonPhraseCategory {
  phraseId   String
  categoryId String
  phrase     CommonPhrase @relation(fields: [phraseId], references: [id], onDelete: Cascade)
  category   Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([phraseId, categoryId])
  @@map("commonPhraseCategories")
}

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  youtubePlaylistId String?
  youtubeApiKey     String?

  accounts      Account[]
  sessions      Session[]
  words         Word[]
  studySessions StudySession[]
  commonPhrases CommonPhrase[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
